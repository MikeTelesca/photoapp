generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("photographer") // "admin" or "photographer"
  avatarUrl          String?
  monthlyAiCostLimit Float   @default(50)  // Default $50/month per user
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  jobs               Job[]
}

model Job {
  id               String   @id @default(cuid())
  address          String
  dropboxUrl       String?
  preset           String   @default("standard") // "standard", "bright-airy", "luxury", "custom"
  tvStyle          String   @default("netflix") // "netflix", "black", "beach", "mountains", "fireplace", "art", "off"
  skyStyle         String   @default("blue-clouds") // "blue-clouds", "clear-blue", "golden-hour", "dramatic", "overcast-soft", "as-is"
  status           String   @default("pending") // "pending", "processing", "review", "approved", "rejected"
  totalPhotos      Int      @default(0)
  processedPhotos  Int      @default(0)
  approvedPhotos   Int      @default(0)
  rejectedPhotos   Int      @default(0)
  twilightCount    Int      @default(0)
  cost             Float    @default(0)
  notes            String?
  watermarkText    String?
  tags             String   @default("")  // comma-separated tags
  clientName       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  photographer     User     @relation(fields: [photographerId], references: [id])
  photographerId   String
  photos           Photo[]

  @@index([photographerId, createdAt(sort: Desc)])
  @@index([status])
}

model Photo {
  id                   String   @id @default(cuid())
  jobId                String
  job                  Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  orderIndex           Int      @default(0)
  status               String   @default("pending") // "pending", "processing", "edited", "approved", "rejected", "regenerating"
  originalUrl          String?
  editedUrl            String?
  thumbnailUrl         String?
  isExterior           Boolean  @default(false)
  isTwilight           Boolean  @default(false)
  twilightInstructions String?
  twilightStyle        String?  // "warm-dusk", "blue-hour", "deep-night"
  customInstructions   String?
  detections           String   @default("[]") // JSON array stored as string
  bracketGroup         Int?     // which bracket group this belongs to
  bracketIndex         Int?     // position within bracket group (0, 1, 2 for 3-bracket)
  exifData             String?  // JSON string of relevant EXIF fields
  fileSizeBytes        Int?
  widthPx              Int?
  heightPx             Int?
  errorMessage         String?
  errorAttempts        Int      @default(0)
  qualityFlags         String?  // JSON: { blurry, underexposed, overexposed, lowContrast }
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([jobId, status])
  @@index([jobId, orderIndex])
}

model Preset {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String   @default("")
  promptModifiers String   @default("")
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Invite {
  id          String   @id @default(cuid())
  token       String   @unique
  email       String?
  role        String   @default("photographer")
  createdById String
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([token])
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String   // "job_created", "job_approved", "job_deleted", "photo_enhanced", "photo_approved", "photo_rejected", "photo_regenerated"
  message   String
  jobId     String?
  photoId   String?
  userId    String?
  metadata  String?  // JSON string for extra data
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([jobId])
}
