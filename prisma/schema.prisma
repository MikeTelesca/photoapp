generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("photographer") // "admin" or "photographer"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]
  agents    Agent[]
  presets   Preset[]
}

model Preset {
  id             String   @id @default(cuid())
  name           String
  slug           String
  prompt         String
  gradient       String?
  photographerId String
  photographer   User     @relation(fields: [photographerId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([photographerId, slug])
  @@index([photographerId])
}

model Agent {
  id             String   @id @default(cuid())
  name           String
  email          String?
  phone          String?
  notes          String?
  dropboxFolder  String?  // path like "/BatchBase/Jane Doe"
  dropboxShareUrl String? // public share link for the agent's root folder
  photographerId String
  photographer   User     @relation(fields: [photographerId], references: [id], onDelete: Cascade)
  jobs           Job[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([photographerId, name])
}

model Job {
  id               String   @id @default(cuid())
  address          String
  dropboxUrl       String?
  preset           String   @default("standard")       // built-in: "standard" | "bright-airy" | "flambient-hdr" | or a user Preset slug
  tvStyle          String   @default("netflix")        // "netflix", "black", "beach", "mountains", "fireplace", "art", "off"
  skyStyle         String   @default("blue-clouds")    // "blue-clouds", "clear-blue", "golden-hour", "dramatic", "overcast-soft", "as-is"
  seasonalStyle    String?                              // "spring" | "summer" | "autumn" | "winter" | "twilight" | null
  status           String   @default("pending")         // "pending", "processing", "review", "approved", "rejected"
  totalPhotos      Int      @default(0)
  processedPhotos  Int      @default(0)
  approvedPhotos   Int      @default(0)
  rejectedPhotos   Int      @default(0)
  notes            String?
  dropboxSyncPath  String?
  dropboxSyncUrl   String?
  dropboxSyncedAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  photographerId     String
  photographer       User      @relation(fields: [photographerId], references: [id], onDelete: Cascade)
  agentId            String?
  agent              Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  photos             Photo[]
  autoenhanceOrderId String?
  enhanceStartedAt   DateTime?

  @@index([photographerId, createdAt(sort: Desc)])
  @@index([status])
  @@index([agentId])
}

model Photo {
  id                 String   @id @default(cuid())
  jobId              String
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  orderIndex         Int      @default(0)
  status             String   @default("pending")  // "pending", "processing", "edited", "approved", "rejected", "regenerating", "failed"
  originalUrl        String?
  editedUrl          String?
  thumbnailUrl       String?
  isExterior         Boolean  @default(false)
  isTwilight         Boolean  @default(false)
  customInstructions String?
  // Per-photo overrides — null means "inherit from the parent Job".
  preset             String?
  tvStyle            String?
  skyStyle           String?
  seasonalStyle      String?
  bracketGroup       Int?
  bracketIndex       Int?
  exifData           String?                      // JSON string
  fileSizeBytes      Int?
  widthPx            Int?
  heightPx           Int?
  errorMessage       String?
  errorAttempts      Int      @default(0)
  retryCount         Int      @default(0)
  maxRetries         Int      @default(3)
  note                  String?
  autoenhanceBracketIds String?  // JSON array of Autoenhance bracket UUIDs uploaded for this photo
  autoenhanceImageId    String?  // Autoenhance output image_id once processed
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([jobId, status])
  @@index([jobId, orderIndex])
}
