generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("photographer") // "admin" or "photographer"
  avatarUrl          String?
  monthlyAiCostLimit Float   @default(50)  // Default $50/month per user
  budgetPerJob       Float   @default(20)  // dollars per job before warning
  emailNotifications Boolean @default(true)
  businessName      String?
  businessEmail     String?
  businessPhone     String?
  businessAddress   String?
  invoiceRate       Float?    @default(50)  // default $/photo for invoicing
  invoicePrefix     String?   @default("INV")
  invoiceCounter    Int       @default(1000)
  jobSequenceCounter Int       @default(0)   // auto-incrementing job sequence
  jobSequencePrefix  String    @default("JOB") // prefix for job numbers
  slackWebhookUrl   String?
  twoFactorEnabled  Boolean  @default(false)
  twoFactorSecret   String?
  watermarkLogoPath String?  // internal Dropbox path to logo PNG
  weeklyDigest      Boolean  @default(true)
  dailySummary      Boolean  @default(false)
  notifyJobReady    Boolean  @default(true)
  notifyClientComment Boolean @default(true)
  notifyPhotoFailed Boolean  @default(true)
  timezone          String?   // IANA format, e.g. "America/Toronto"
  emailSignature    String?
  autoArchiveDays   Int?      // null = disabled; otherwise days
  promptPrefix      String?   // Custom prompt prefix prepended to all enhance prompts
  filenamePattern   String   @default("{address}-{seq}") // Download filename pattern
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  jobs               Job[]
  jobTemplates       JobTemplate[]
  clients            Client[]
  passwordResetTokens PasswordResetToken[]
  loginRecords       LoginRecord[]
  notifications      Notification[]
  apiKeys            ApiKey[]
  noteTemplates      NoteTemplate[]
  jobComments        JobComment[] @relation("JobCommentAuthor")
  pushSubscriptions  PushSubscription[]
  feedbackReports    FeedbackReport[]
}

model LoginRecord {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  notes     String?
  defaultPreset String?
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  jobs      Job[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Job {
  id               String   @id @default(cuid())
  address          String
  dropboxUrl       String?
  preset           String   @default("standard") // "standard", "bright-airy", "luxury", "custom"
  tvStyle          String   @default("netflix") // "netflix", "black", "beach", "mountains", "fireplace", "art", "off"
  skyStyle         String   @default("blue-clouds") // "blue-clouds", "clear-blue", "golden-hour", "dramatic", "overcast-soft", "as-is"
  seasonalStyle    String?  // "spring" | "summer" | "autumn" | "winter" | "twilight" | null
  priority         String   @default("medium") // "high" | "medium" | "low"
  status           String   @default("pending") // "pending", "processing", "review", "approved", "rejected"
  totalPhotos      Int      @default(0)
  processedPhotos  Int      @default(0)
  approvedPhotos   Int      @default(0)
  rejectedPhotos   Int      @default(0)
  twilightCount    Int      @default(0)
  cost             Float    @default(0)
  notes            String?
  watermarkText     String?
  watermarkPosition String  @default("bottom-right")  // top-left, top-right, bottom-left, bottom-right, center
  watermarkSize     Int     @default(32)              // font size in px
  watermarkOpacity  Float   @default(0.7)
  tags             String   @default("")  // comma-separated tags
  clientName       String?
  clientId         String?
  client           Client?  @relation(fields: [clientId], references: [id])
  customPromptOverride String?  // per-job custom instructions for AI enhance
  sequenceNumber   Int?     // auto-incrementing per user
  shareToken          String?  @unique
  shareEnabled        Boolean  @default(false)
  sharePassword       String?  // bcrypt hash when set
  shareExpiresAt      DateTime?
  listingDescription  String?
  archivedAt          DateTime?
  dropboxSyncPath     String?
  dropboxSyncUrl      String?
  dropboxSyncedAt     DateTime?
  invoicePaidAt       DateTime?
  invoiceSentAt       DateTime?
  pinnedAt            DateTime?
  snoozedUntil        DateTime?
  trackedTimeSeconds  Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt        DateTime @updatedAt
  photographer     User     @relation(fields: [photographerId], references: [id], onDelete: Cascade)
  photographerId   String
  photos           Photo[]
  shareEmailLogs   ShareEmailLog[]
  jobComments      JobComment[]
  shareRequests    ShareRequest[]

  @@index([photographerId, createdAt(sort: Desc)])
  @@index([status])
}

model Photo {
  id                   String   @id @default(cuid())
  jobId                String
  job                  Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  orderIndex           Int      @default(0)
  status               String   @default("pending") // "pending", "processing", "edited", "approved", "rejected", "regenerating", "failed"
  originalUrl          String?
  editedUrl            String?
  thumbnailUrl         String?
  isExterior           Boolean  @default(false)
  isTwilight           Boolean  @default(false)
  isFavorite           Boolean  @default(false)
  flagged              Boolean  @default(false)
  twilightInstructions String?
  twilightStyle        String?  // "warm-dusk", "blue-hour", "deep-night"
  customInstructions   String?
  detections           String   @default("[]") // JSON array stored as string
  bracketGroup         Int?     // which bracket group this belongs to
  bracketIndex         Int?     // position within bracket group (0, 1, 2 for 3-bracket)
  exifData             String?  // JSON string of relevant EXIF fields
  fileSizeBytes        Int?
  widthPx              Int?
  heightPx             Int?
  errorMessage         String?
  errorAttempts        Int      @default(0)
  retryCount           Int      @default(0)
  maxRetries           Int      @default(3)
  qualityFlags         String?  // JSON: { blurry, underexposed, overexposed, lowContrast }
  autoTags             String?  // JSON array of detected tags: ["kitchen", "interior", "bright"]
  rejectionReason      String?
  note                 String?
  caption              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  comments             PhotoComment[]
  ratings              PhotoRating[]
  versions             PhotoVersion[]

  @@index([jobId, status])
  @@index([jobId, orderIndex])
}

model PhotoVersion {
  id        String   @id @default(cuid())
  photoId   String
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  url       String
  preset    String?
  createdAt DateTime @default(now())

  @@index([photoId, createdAt])
}

model PhotoComment {
  id          String   @id @default(cuid())
  photoId     String
  photo       Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  authorName  String
  message     String
  createdAt   DateTime @default(now())

  @@index([photoId])
}

model PhotoRating {
  id          String   @id @default(cuid())
  photoId     String
  photo       Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  authorName  String
  rating      Int      // 1-5
  createdAt   DateTime @default(now())

  @@index([photoId])
}

model JobTemplate {
  id               String   @id @default(cuid())
  name             String
  ownerId          String
  owner            User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  preset           String   @default("standard")
  tvStyle          String?
  skyStyle         String?
  watermarkText    String?
  photographerName String?
  clientName       String?
  tags             String?
  notes            String?
  createdAt        DateTime @default(now())

  @@index([ownerId])
}

model Preset {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String   @default("")
  promptModifiers String   @default("")
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Invite {
  id          String   @id @default(cuid())
  token       String   @unique
  email       String?
  role        String   @default("photographer")
  createdById String
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([token])
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String   // "job_created", "job_approved", "job_deleted", "photo_enhanced", "photo_approved", "photo_rejected", "photo_regenerated"
  message   String
  jobId     String?
  photoId   String?
  userId    String?
  metadata  String?  // JSON string for extra data
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([jobId])
}

model ErrorLog {
  id        String   @id @default(cuid())
  source    String   // "enhance", "ingest", "upload", "stuck-recovery", etc.
  message   String
  jobId     String?
  photoId   String?
  userId    String?
  metadata  String?  // JSON string for extra data
  createdAt DateTime @default(now())

  @@index([source, createdAt(sort: Desc)])
  @@index([jobId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "job-ready", "photo-failed", "client-comment", "digest"
  title     String
  body      String?
  href      String?  // link to act on it
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model Announcement {
  id        String   @id @default(cuid())
  message   String
  type      String   @default("info") // "info", "warning", "success"
  active    Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())

  @@index([active, createdAt])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model ShareEmailLog {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  toEmail   String
  sentAt    DateTime @default(now())
  sentBy    String?

  @@index([jobId])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([userId])
  @@index([keyHash])
}

model NoteTemplate {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  category  String?  // "job" | "photo" | "general"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, category])
}

model JobComment {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("JobCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([jobId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model DownloadLog {
  id        String   @id @default(cuid())
  userId    String?
  jobId     String?
  photoId   String?
  type      String   // "zip" | "mls" | "single" | "invoice" | "pdf-gallery"
  preset    String?
  count     Int?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([jobId, createdAt])
}

model FeedbackReport {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  category  String   // "bug" | "feature" | "question" | "other"
  message   String
  metadata  String?  // JSON: page url, user-agent
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([resolved, createdAt])
}

model ShareRequest {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fromName    String
  fromEmail   String?
  message     String
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([jobId, createdAt])
}
