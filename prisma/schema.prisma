generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("photographer") // "admin" or "photographer"
  avatarUrl          String?
  monthlyAiCostLimit Float   @default(50)  // Default $50/month per user
  emailNotifications Boolean @default(true)
  businessName      String?
  businessEmail     String?
  businessPhone     String?
  businessAddress   String?
  invoiceRate       Float?    @default(50)  // default $/photo for invoicing
  invoicePrefix     String?   @default("INV")
  invoiceCounter    Int       @default(1000)
  slackWebhookUrl   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  jobs               Job[]
  jobTemplates       JobTemplate[]
  clients            Client[]
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  notes     String?
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  jobs      Job[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Job {
  id               String   @id @default(cuid())
  address          String
  dropboxUrl       String?
  preset           String   @default("standard") // "standard", "bright-airy", "luxury", "custom"
  tvStyle          String   @default("netflix") // "netflix", "black", "beach", "mountains", "fireplace", "art", "off"
  skyStyle         String   @default("blue-clouds") // "blue-clouds", "clear-blue", "golden-hour", "dramatic", "overcast-soft", "as-is"
  status           String   @default("pending") // "pending", "processing", "review", "approved", "rejected"
  totalPhotos      Int      @default(0)
  processedPhotos  Int      @default(0)
  approvedPhotos   Int      @default(0)
  rejectedPhotos   Int      @default(0)
  twilightCount    Int      @default(0)
  cost             Float    @default(0)
  notes            String?
  watermarkText     String?
  watermarkPosition String  @default("bottom-right")  // top-left, top-right, bottom-left, bottom-right, center
  watermarkSize     Int     @default(32)              // font size in px
  watermarkOpacity  Float   @default(0.7)
  tags             String   @default("")  // comma-separated tags
  clientName       String?
  clientId         String?
  client           Client?  @relation(fields: [clientId], references: [id])
  shareToken          String?  @unique
  shareEnabled        Boolean  @default(false)
  listingDescription  String?
  createdAt           DateTime @default(now())
  updatedAt        DateTime @updatedAt
  photographer     User     @relation(fields: [photographerId], references: [id])
  photographerId   String
  photos           Photo[]

  @@index([photographerId, createdAt(sort: Desc)])
  @@index([status])
}

model Photo {
  id                   String   @id @default(cuid())
  jobId                String
  job                  Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  orderIndex           Int      @default(0)
  status               String   @default("pending") // "pending", "processing", "edited", "approved", "rejected", "regenerating"
  originalUrl          String?
  editedUrl            String?
  thumbnailUrl         String?
  isExterior           Boolean  @default(false)
  isTwilight           Boolean  @default(false)
  isFavorite           Boolean  @default(false)
  twilightInstructions String?
  twilightStyle        String?  // "warm-dusk", "blue-hour", "deep-night"
  customInstructions   String?
  detections           String   @default("[]") // JSON array stored as string
  bracketGroup         Int?     // which bracket group this belongs to
  bracketIndex         Int?     // position within bracket group (0, 1, 2 for 3-bracket)
  exifData             String?  // JSON string of relevant EXIF fields
  fileSizeBytes        Int?
  widthPx              Int?
  heightPx             Int?
  errorMessage         String?
  errorAttempts        Int      @default(0)
  qualityFlags         String?  // JSON: { blurry, underexposed, overexposed, lowContrast }
  rejectionReason      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  comments             PhotoComment[]

  @@index([jobId, status])
  @@index([jobId, orderIndex])
}

model PhotoComment {
  id          String   @id @default(cuid())
  photoId     String
  photo       Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  authorName  String
  message     String
  createdAt   DateTime @default(now())

  @@index([photoId])
}

model JobTemplate {
  id               String   @id @default(cuid())
  name             String
  ownerId          String
  owner            User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  preset           String   @default("standard")
  tvStyle          String?
  skyStyle         String?
  watermarkText    String?
  photographerName String?
  clientName       String?
  tags             String?
  notes            String?
  createdAt        DateTime @default(now())

  @@index([ownerId])
}

model Preset {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String   @default("")
  promptModifiers String   @default("")
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Invite {
  id          String   @id @default(cuid())
  token       String   @unique
  email       String?
  role        String   @default("photographer")
  createdById String
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([token])
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String   // "job_created", "job_approved", "job_deleted", "photo_enhanced", "photo_approved", "photo_rejected", "photo_regenerated"
  message   String
  jobId     String?
  photoId   String?
  userId    String?
  metadata  String?  // JSON string for extra data
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([jobId])
}

model ErrorLog {
  id        String   @id @default(cuid())
  source    String   // "enhance", "ingest", "upload", "stuck-recovery", etc.
  message   String
  jobId     String?
  photoId   String?
  userId    String?
  metadata  String?  // JSON string for extra data
  createdAt DateTime @default(now())

  @@index([source, createdAt(sort: Desc)])
  @@index([jobId])
}
