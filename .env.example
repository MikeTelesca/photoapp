# Database
# For development, SQLite is fine: file:./dev.db
# For production, use Neon: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
# NEXTAUTH_SECRET: Generate a random string (min 32 bytes)
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="dev-local-secret-change-for-production-with-random-32-bytes"

# Your app URL (used for OAuth callbacks and session security)
NEXTAUTH_URL="http://localhost:3000"

# Dropbox OAuth Configuration
# Get these from https://www.dropbox.com/developers/apps
#
# Option 1: Short-lived access token (for development/testing)
# DROPBOX_ACCESS_TOKEN="sl.u...."
#
# Option 2: Long-lived OAuth (recommended for production)
# Create an app, generate refresh token, and use these:
DROPBOX_APP_KEY="your_app_key_here"
DROPBOX_APP_SECRET="your_app_secret_here"
DROPBOX_REFRESH_TOKEN="your_refresh_token_here"

# Google Generative AI
# Get your API key from https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY="your_api_key_here"

# Optional: Gemini Model Override
# If you want to use a different model, set this to the model name
# Default cascade: gemini-3-pro-image-preview → gemini-3.1-flash-image-preview → gemini-2.5-flash-image
# GEMINI_MODEL="gemini-3-pro-image-preview"

# Optional: Feature Flags
# NODE_ENV="development"           # development, production, test
# LOG_LEVEL="debug"                # debug, info, warn, error

# Optional: Sentry (error tracking)
# NEXT_PUBLIC_SENTRY_DSN="https://..."
